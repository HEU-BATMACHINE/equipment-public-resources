mixer:hasMixerMachineDimensionSpaceAbove rdf:type owl:DatatypeProperty ;
                                         rdfs:domain mixer:MixerEquipment ;
                                         rdfs:range xsd:float ;
                                         rdfs:comment "Space required above the mixer." ;
                                         rdfs:label "has Mixer Machine Space Above" .


mixer:hasMixerMachineDimensionWidth rdf:type owl:DatatypeProperty ;
                                    rdfs:domain mixer:MixerEquipment ;
                                    rdfs:range xsd:float ;
