                            rdfs:label "has Mixer Total Capacity" .


mixer:MixerDevice rdf:type owl:Class ;
                  rdfs:subClassOf equipment:ManufacturingDevice ;
                  rdfs:comment "Mixer device for the production of electrode slurry, corresponding to the main mixing chamber."@en ;
                  rdfs:label "MixerDevice"@en ;
                  skos:prefLabel "MixerDevice"@en .


mixer:MixerEquipment rdf:type owl:Class ;
                     rdfs:subClassOf equipment:ManufacturingEquipment ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty equipment:hasDevice ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass mixer:MixerDevice
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty equipment:hasDevice ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass mixer:MixerPumpDevice
                                     ] ;
                     rdfs:comment "Mixer equipment for the production of electrode slurry."@en ;
                     rdfs:label "MixerEquipment"@en ;
                     skos:prefLabel "MixerEquipment"@en .


mixer:MixerPumpDevice rdf:type owl:Class ;
                      rdfs:subClassOf equipment:ManufacturingDevice ;
                      rdfs:comment "Mixer Pump device for the production of electrode slurry, corresponding to the pump circulating the slurry."@en ;
                      rdfs:label "MixerPumpDevice"@en ;
                      skos:prefLabel "MixerPumpDevice"@en .

mixer:PumpDevice rdf:type owl:Class .


mixer:SlurryMixingProcess rdf:type owl:Class ;
                          rdfs:subClassOf emmo:EMMO_a4d66059_5dd3_4b90_b4cb_10960559441b ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty equipment:hasDevice ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass mixer:MixerDevice
                                          ] ;
                          rdfs:comment "Mixing of slurry for electrodes."@en ;
                          rdfs:label "SlurryMixingProcess"@en ;
                          skos:prefLabel "SlurryMixingProcess"@en .


mixer:SlurryPumpingProcess rdf:type owl:Class ;
                           rdfs:subClassOf emmo:EMMO_71d1c8f0_c6e3_44b5_a4b6_1b74ff35698a ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty equipment:hasDevice ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onClass mixer:PumpDevice
                                           ] ;
                           rdfs:comment "Process of slurry pumping."@en ;
                           rdfs:label "SlurryPumpingProcess"@en ;
                           skos:prefLabel "SlurryPumpingProcess"@en .
